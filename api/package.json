{
  "name": "tongzhou-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --import tsx src/index.ts",
    "seed": "tsx src/db/seed.ts",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "smoke": "tsx scripts/smoke.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:pg": "vitest run --project postgres"
  },
  "dependencies": {
    "@fastify/cookie": "11.0.2",
    "@fastify/cors": "10.0.1",
    "@fastify/multipart": "9.0.1",
    "bcryptjs": "3.0.3",
    "better-sqlite3": "11.7.0",
    "cos-nodejs-sdk-v5": "2.15.4",
    "fastify": "5.1.0",
    "jose": "6.2.3",
    "pg": "8.20.0",
    "tencentcloud-sdk-nodejs-vod": "4.1.232"
  },
  "devDependencies": {
    "@eslint/js": "9.39.1",
    "@types/better-sqlite3": "7.6.12",
    "@types/node": "22.10.7",
    "@types/pg": "8.20.0",
    "eslint": "9.39.1",
    "eslint-config-prettier": "10.1.8",
    "globals": "16.5.0",
    "prettier": "3.6.2",
    "tsx": "4.19.2",
    "typescript-eslint": "8.46.3",
    "typescript": "5.7.3",
    "vitest": "3.2.4"
  }
}
