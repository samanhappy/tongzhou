# 同舟 · API 配置
# 启动时这些环境变量决定 DB / Cache / Storage 用哪个适配器

# --- 服务 ---
PORT=4100
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:4173

# --- DB ---
# sqlite | postgres
DB_DRIVER=sqlite
# sqlite 路径（DB_DRIVER=sqlite 时）
DB_SQLITE_PATH=./data/tongzhou.db
# postgres 连接串（DB_DRIVER=postgres 时；MVP 未实现）
# DATABASE_URL=postgres://localhost:5432/tongzhou

# --- Cache ---
# memory | redis
CACHE_DRIVER=memory
# REDIS_URL=redis://localhost:6379

# --- Storage（视频 / 海报）---
# local | tencent-cos
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./uploads
STORAGE_PUBLIC_BASE=http://localhost:4100/files

# 腾讯云 COS（STORAGE_DRIVER=tencent-cos 时；MVP 未实现）
# COS_SECRET_ID=
# COS_SECRET_KEY=
# COS_BUCKET=
# COS_REGION=ap-shanghai
# COS_CDN_DOMAIN=
