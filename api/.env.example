# 同舟 · API 配置
#
# 默认配置：sqlite + memory + local — 零依赖,零成本起步
# 切真生产：postgres + memory (V0 暂不上 redis) + tencent-cos + tencent-vod

# ─── 服务 ───
PORT=4100
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:4173

# ─── Auth ───
# 开发时允许 x-tenant-slug 回退,不破坏 demo；生产务必关掉。
AUTH_DEV_MODE=true
# 至少 32 字符随机串,用于 JWT 签名
AUTH_JWT_SECRET=replace-with-a-random-32-char-secret

# ─── DB ───
# sqlite | postgres
DB_DRIVER=sqlite
DB_SQLITE_PATH=./data/tongzhou.db
# 切 PG 时取消注释下面这行（也支持 docker-compose 默认账号）：
# DB_DRIVER=postgres
# DATABASE_URL=postgres://tongzhou:tongzhou@localhost:5432/tongzhou

# ─── Cache ───
# memory | redis
CACHE_DRIVER=memory
# REDIS_URL=redis://localhost:6379

# ─── Storage(海报、Logo、非视频文件)───
# local | tencent-cos
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./uploads
STORAGE_PUBLIC_BASE=http://localhost:4100/files

# 切腾讯云 COS:
# STORAGE_DRIVER=tencent-cos
# COS_SECRET_ID=你的访问密钥 ID
# COS_SECRET_KEY=你的访问密钥
# COS_BUCKET=tongzhou-prod-1300000000      # 形如 <name>-<appid>
# COS_REGION=ap-shanghai
# COS_CDN_DOMAIN=https://cdn.your-domain.com   # 建议开 CDN + 防盗链

# ─── Video(视频专用,带 playAuth)───
# local | tencent-vod
VIDEO_DRIVER=local

# 切腾讯云 VOD:
# VIDEO_DRIVER=tencent-vod
# VOD_SECRET_ID=同上(或独立 STS 账号)
# VOD_SECRET_KEY=
# VOD_REGION=ap-shanghai
# VOD_SUB_APP_ID=1500000000               # 子应用 ID(主应用可留空)
# VOD_PLAY_KEY=                            # 控制台「分发播放设置 → Key 防盗链」复制
